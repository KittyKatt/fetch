{
    "files.eol": "\n",
    "files.insertFinalNewline": true,
    "editor.detectIndentation": false,
    "editor.insertSpaces": true,
    "workbench.editor.highlightModifiedTabs": true,
    "[yaml]": {

        "editor.insertSpaces": true,
        "editor.tabSize": 2,
        "editor.autoIndent": "advanced",
        "gitlens.codeLens.scopes": [
            "document"
        ]
    },
    "workbench.colorCustomizations": {
        "editorGroup.border": "#fc1374",
        "panel.border": "#fc1374",
        "sideBar.border": "#fc1374",
        "statusBar.background": "#d9035c",
        "statusBarItem.hoverBackground": "#fc1374",
        "activityBar.activeBackground": "#fc1374",
        "activityBar.activeBorder": "#285e01",
        "activityBar.background": "#fc1374",
        "activityBarBadge.background": "#285e01",
        "activityBarBadge.foreground": "#e7e7e7",
        "activityBar.foreground": "#e7e7e7",
        "activityBar.inactiveForeground": "#e7e7e799",
        "statusBar.foreground": "#e7e7e7"
    },
    "peacock.color": "#d9035c"
}
